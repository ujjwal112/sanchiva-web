# Copy to server/.env for local development (never commit real secrets)

# PostgreSQL
DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker
PGHOST=localhost
PGPORT=5432
PGUSER=expense_user
PGPASSWORD=expense_pass
PGDATABASE=expense_tracker

# Server
PORT=5000
# Comma-separated browser origins, or * for open CORS in demo deploys
CLIENT_ORIGIN=http://localhost:5173

# Client (optional, for split hosting — put in client/.env.production)
# VITE_API_URL=https://your-api.onrender.com

# Public app URL (OAuth redirects)
APP_URL=https://sanchiva.onrender.com
API_URL=https://sanchiva.onrender.com

# JWT secrets (generate long random strings)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=30

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (https://developers.facebook.com/)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Microsoft OAuth (https://portal.azure.com/ → App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
